{
  "kind": "singleType",
  "collectionName": "globals",
  "info": {
    "singularName": "global",
    "pluralName": "globals",
    "displayName": "Global",
    "description": "Site-wide footer/contact/social data — written to satisfy EP-02-S1, replacing footer_content.json + load-footer.js."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "siteName": {
      "type": "string",
      "default": "TrieDatum"
    },
    "usAddress": {
      "type": "text"
    },
    "indiaAddress": {
      "type": "text"
    },
    "email": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "phoneClean": {
      "type": "string"
    },
    "copyrightYear": {
      "type": "integer",
      "default": 2026
    },
    "footerLinks": {
      "type": "component",
      "repeatable": true,
      "component": "shared.link"
    },
    "social": {
      "type": "component",
      "repeatable": true,
      "component": "shared.social-link"
    }
  }
}
